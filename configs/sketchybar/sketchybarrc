#!/usr/bin/env bash
# sketchybar — minimal top bar, black metal gorgoroth palette.
# Left: macOS spaces + focused app. Right: battery, volume, clock.
# Docs: https://felixkratz.github.io/SketchyBar/

PLUGIN_DIR="$CONFIG_DIR/plugins"

BG=0xf0000000      # bar background (near-opaque black)
FG=0xffc1c1c1      # default text
DIM=0xff505050     # inactive / separators
ACCENT=0xff5f8787  # active space (gorgoroth teal)

sketchybar --bar \
  height=26 \
  color=$BG \
  position=top \
  padding_left=6 \
  padding_right=6

sketchybar --default \
  icon.font="IosevkaTerm Nerd Font Mono:Regular:13.0" \
  label.font="IosevkaTerm Nerd Font Mono:Regular:13.0" \
  icon.color=$FG \
  label.color=$FG \
  icon.padding_left=4 icon.padding_right=4 \
  label.padding_left=4 label.padding_right=4

# --- Left: named spaces ---
# Names are per POSITION: space 1 = leftmost, and so on. macOS won't enforce
# what actually runs where — these are just labels for what each slot is *for*.
# Edit the array to rename; a space only draws once it exists in Mission Control.
SPACE_NAMES=(work music web media notes scratch misc)

sid=1
for name in "${SPACE_NAMES[@]}"; do
  sketchybar --add space space.$sid left \
    --set space.$sid space=$sid icon=$sid label="$name" \
      icon.color=$DIM icon.highlight_color=$ACCENT \
      label.color=$DIM label.highlight_color=$ACCENT \
      icon.padding_right=3 \
      script="$PLUGIN_DIR/space.sh"
  sid=$((sid + 1))
done

# --- Right: clock, volume, battery ---
sketchybar --add item clock right \
  --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh"

sketchybar --add item volume right \
  --set volume script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

sketchybar --add item battery right \
  --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

sketchybar --update
